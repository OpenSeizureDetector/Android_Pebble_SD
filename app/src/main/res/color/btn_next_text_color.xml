<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Enabled state: Use button text color (matches Back/Skip buttons) -->
    <item android:state_enabled="true" android:color="@color/button_text_color" />
