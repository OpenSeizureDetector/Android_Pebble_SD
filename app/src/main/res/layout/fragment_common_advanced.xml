<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="4dp"
    android:gravity="top"
    tools:context=".activity.main.FragmentCommon">

    <TextView
        android:id="@+id/data_time_tv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="---"
        android:textSize="14sp"
        android:gravity="center"
        android:paddingBottom="2dp"
        android:textStyle="italic"
        android:alpha="0.8" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/alarmStatusCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="2dp"
        app:cardElevation="2dp"
        app:cardCornerRadius="8dp">

        <LinearLayout
            android:id="@+id/alarm_status_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="4dp"
            android:gravity="center">

            <TextView
                android:id="@+id/system_status_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SYSTEM STATUS"
                android:textSize="10sp"
                android:visibility="gone"
                android:letterSpacing="0.1"
                android:textAllCaps="true"
                android:alpha="0.6"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/alarmTv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="---"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="center"
                android:maxLines="2"
                android:ellipsize="end" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/algorithmsCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="2dp"
        app:cardElevation="2dp"
        app:cardCornerRadius="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="6dp">

            <TextView
                android:id="@+id/algorithms_title_tv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Active Algorithms"
                android:textSize="11sp"
                android:alpha="0.7"
                android:gravity="center"
                android:layout_marginBottom="2dp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/algorithms_status_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:padding="0dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/buttonContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="0dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/acceptAlarmButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="2dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            style="@style/Widget.Material3.Button.TonalButton"
            android:text="@string/AcceptAlarmBtnTxt"
            android:textSize="11sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/cancelAudibleButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            style="@style/Widget.Material3.Button.TonalButton"
            android:text="@string/CancelAudibleButtonTxt"
            android:textSize="11sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/manualAlarmButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="2dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            style="@style/Widget.Material3.Button"
            android:text="@string/ManualAlarmBtnTxt"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
