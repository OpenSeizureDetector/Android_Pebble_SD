<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorPrimary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Choose Data Source"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select where seizure detection data will come from:"
            android:textSize="14sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="24dp" />

        <RadioGroup
            android:id="@+id/data_source_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <RadioButton
                android:id="@+id/radio_phone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Phone (Demo Mode)"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="16sp"
                android:padding="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Uses phone's accelerometer for testing. Not suitable for real seizure detection."
                android:textSize="12sp"
                android:textColor="?android:attr/textColorSecondary"
                android:paddingStart="48dp"
                android:paddingEnd="12dp"
                android:paddingBottom="8dp" />

            <RadioButton
                android:id="@+id/radio_pinetime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PineTime Watch"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="16sp"
                android:padding="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Recommended. Uses a low-cost PineTime watch worn on the wrist for accurate detection."
                android:textSize="12sp"
                android:textColor="?android:attr/textColorSecondary"
                android:paddingStart="48dp"
                android:paddingEnd="12dp"
                android:paddingBottom="8dp" />

            <RadioButton
                android:id="@+id/radio_garmin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Garmin Watch"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="16sp"
                android:padding="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Uses a Garmin smart watch worn on the wrist for accurate detection and heart rate monitoring."
                android:textSize="12sp"
                android:textColor="?android:attr/textColorSecondary"
                android:paddingStart="48dp"
                android:paddingEnd="12dp"
                android:paddingBottom="8dp" />

            <RadioButton
                android:id="@+id/radio_network"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Network (Remote Monitoring)"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="16sp"
                android:padding="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Connect to another device running OpenSeizureDetector for remote alarm annunciation."
                android:textSize="12sp"
                android:textColor="?android:attr/textColorSecondary"
                android:paddingStart="48dp"
                android:paddingEnd="12dp"
                android:paddingBottom="8dp" />

        </RadioGroup>


    </LinearLayout>
</ScrollView>
