<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/onboarding_datasource_title"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/onboarding_datasource_subtitle"
            android:textSize="14sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="24dp" />

        <RadioGroup
            android:id="@+id/data_source_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <RadioButton
                android:id="@+id/radio_phone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/onboarding_datasource_phone"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="16sp"
                android:padding="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/onboarding_datasource_phone_desc"
                android:textSize="12sp"
                android:textColor="?android:attr/textColorSecondary"
                android:paddingStart="48dp"
                android:paddingEnd="12dp"
                android:paddingBottom="8dp" />

            <RadioButton
                android:id="@+id/radio_pinetime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/onboarding_datasource_pinetime"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="16sp"
                android:padding="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/onboarding_datasource_pinetime_desc"
                android:textSize="12sp"
                android:textColor="?android:attr/textColorSecondary"
                android:paddingStart="48dp"
                android:paddingEnd="12dp"
                android:paddingBottom="8dp" />

            <RadioButton
                android:id="@+id/radio_garmin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/onboarding_datasource_garmin"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="16sp"
                android:padding="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/onboarding_datasource_garmin_desc"
                android:textSize="12sp"
                android:textColor="?android:attr/textColorSecondary"
                android:paddingStart="48dp"
                android:paddingEnd="12dp"
                android:paddingBottom="8dp" />

            <RadioButton
                android:id="@+id/radio_network"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/onboarding_datasource_network"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="16sp"
                android:padding="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/onboarding_datasource_network_desc"
                android:textSize="12sp"
                android:textColor="?android:attr/textColorSecondary"
                android:paddingStart="48dp"
                android:paddingEnd="12dp"
                android:paddingBottom="8dp" />

        </RadioGroup>


    </LinearLayout>
</ScrollView>
