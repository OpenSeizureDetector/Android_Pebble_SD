<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    tools:context=".FragmentOsdBaseClass">

    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="?attr/colorPrimary"
        >


        <TextView
            android:id="@+id/serverStatusTv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="---" />

        <TextView
            android:id="@+id/dataSourceInfoTv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="---" />

        <TextView
            android:id="@+id/data_time_tv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="---" />

        <!-- Overall Alarm Status Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/alarmStatusCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            app:cardElevation="6dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/card_background_light_blue">

            <TextView
                android:id="@+id/alarmTv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="---"
                android:textSize="36sp"
                android:textStyle="bold"
                android:padding="20dp" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Algorithm Status Card - Compact Single Row -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/algorithmsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="8dp"
            app:cardElevation="6dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/card_background_light_blue">

            <LinearLayout
                android:id="@+id/algorithms_status_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center" />

        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/acceptAlarmButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:minHeight="56dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="@color/button_stroke_color"
                android:textColor="@color/button_text_color"
                android:text="@string/AcceptAlarmBtnTxt" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/cancelAudibleButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:minHeight="56dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="@color/button_stroke_color"
                android:textColor="@color/button_text_color"
                android:text="@string/CancelAudibleButtonTxt" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/manualAlarmButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:minHeight="56dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                style="@style/Widget.MaterialComponents.Button"
                android:backgroundTint="#ff0000"
                android:textColor="@color/button_text_color"
                android:text="@string/ManualAlarmBtnTxt" />
        </LinearLayout>


    </androidx.appcompat.widget.LinearLayoutCompat>


</FrameLayout>