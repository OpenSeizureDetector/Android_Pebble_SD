<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    tools:context=".activity.main.FragmentCommon">

    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/data_time_tv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="---"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Overall Alarm Status Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/alarmStatusCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            app:cardElevation="1dp"
            app:cardCornerRadius="6dp">

            <TextView
                android:id="@+id/alarmTv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="---"
                android:textSize="24sp"
                android:textStyle="bold"
                android:padding="8dp" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Algorithm Status Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/algorithmsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            app:cardElevation="1dp"
            app:cardCornerRadius="6dp">

            <LinearLayout
                android:id="@+id/algorithms_status_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="4dp"
                android:gravity="center" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Centered button row with consistent Material Design 3 styling -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:spacing="2dp">

            <!-- Accept Alarm button - secondary action (tonal) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/acceptAlarmButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                style="@style/Widget.Material3.Button.TonalButton"
                android:text="@string/AcceptAlarmBtnTxt"
                android:textSize="11sp" />

            <!-- Mute/Cancel Audible button - secondary action (tonal button with visible background) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/cancelAudibleButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="4dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                style="@style/Widget.Material3.Button.TonalButton"
                android:text="@string/CancelAudibleButtonTxt"
                android:textSize="11sp" />

            <!-- Raise Alarm button - primary action (prominent filled button) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/manualAlarmButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="2dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                style="@style/Widget.Material3.Button"
                android:text="@string/ManualAlarmBtnTxt"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

    </androidx.appcompat.widget.LinearLayoutCompat>

</FrameLayout>
