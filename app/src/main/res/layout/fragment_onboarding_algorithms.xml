<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorPrimary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select Detection Algorithms"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Choose which seizure detection algorithms to use. You can enable multiple algorithms."
            android:textSize="14sp"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginBottom="24dp" />

        <!-- ML Algorithm - First (Recommended) -->
        <CheckBox
            android:id="@+id/check_ml_alg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ML Algorithm (Recommended)"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:padding="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Machine Learning ('AI') detection.\nGives good seizure detection reliability with fewer false alarms than the original OSD Algorithm.\nFalse alarm performance should improve over time as users report false alarms and real seizures using our 'Data Sharing' facility."
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary"
            android:paddingStart="48dp"
            android:paddingEnd="12dp"
            android:paddingBottom="12dp" />

        <!-- Heart Rate Algorithm - Second -->
        <CheckBox
            android:id="@+id/check_hr_alg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Heart Rate Alerts"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="16sp"
            android:padding="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Detects abnormal heart rate patterns. Currently requires Garmin watch for reliable heart rate measurement."
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary"
            android:paddingStart="48dp"
            android:paddingEnd="12dp"
            android:paddingBottom="12dp" />

        <!-- Original OSD Algorithm - Third -->
        <CheckBox
            android:id="@+id/check_osd_alg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="OSD Algorithm"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="16sp"
            android:checked="true"
            android:padding="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Original OpenSeizureDetector Deterministic Algorithm (OSD)\nProven tonic-clonic seizure detection - good for night time use, but gives false alarms for some normal activities that involve repetitive movements (brushing teeth, washing dishes etc.)."
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary"
            android:paddingStart="48dp"
            android:paddingEnd="12dp"
            android:paddingBottom="12dp" />

        <!-- OSD with Flap Detection - Fourth -->
        <CheckBox
            android:id="@+id/check_flap_alg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="OSD Algorithm with 'Flap' Detection"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="16sp"
            android:padding="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enhanced OSD algorithm that detects arm flapping movements for maximum night time tonic-clonic seizure detection performance."
            android:textSize="12sp"
            android:textColor="?android:attr/textColorSecondary"
            android:paddingStart="48dp"
            android:paddingEnd="12dp"
            android:paddingBottom="12dp" />

        <!-- Configuration Message Container -->
        <FrameLayout
            android:id="@+id/config_message_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:visibility="gone" />



        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Note: At least one algorithm should be enabled for seizure detection to work."
            android:textSize="12sp"
            android:textStyle="italic"
            android:textColor="?android:attr/textColorSecondary"
            android:layout_marginTop="16dp" />

    </LinearLayout>
</ScrollView>
