<?xml version="1.0" encoding="utf-8"?>
<!-- Landscape-optimized StartupActivity layout -->
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/startup_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="uk.org.openseizuredetector.activity.startup.StartupActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="12dp">

    <!-- Header: Logo and App Name (Horizontal) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <ImageView
            android:id="@+id/imageView"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginEnd="16dp"
            android:contentDescription="@string/app_name"
            app:srcCompat="@drawable/star_of_life_48x48" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/appNameTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OpenSeizureDetector"
                android:textAppearance="?android:attr/textAppearanceLarge"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/dataSourceTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/StartingTitle"
                android:textAppearance="?android:attr/textAppearanceMedium" />
        </LinearLayout>
    </LinearLayout>

    <!-- Action Buttons (3 columns) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp"
        android:gravity="center">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/instructionsButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="Help"
            style="@style/Widget.Material3.Button.TonalButton" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/troubleshootingButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:text="Troubleshoot"
            style="@style/Widget.Material3.Button.TonalButton" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/settingsButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="@string/edit_settings"
            style="@style/Widget.Material3.Button.TonalButton" />
    </LinearLayout>

    <!-- Status Items: 2-Column Grid -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:columnCount="2"
        android:rowCount="3"
        android:alignmentMode="alignMargins"
        android:columnOrderPreserved="false">

        <!-- Status Item 1: Permissions -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="8dp"
            android:layout_row="0"
            android:layout_column="0"
            android:layout_columnWeight="1"
            android:layout_marginEnd="4dp">

            <ProgressBar
                android:id="@+id/progressBar1"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/textItem1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Permissions"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Status Item 2: Service Status -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="8dp"
            android:layout_row="0"
            android:layout_column="1"
            android:layout_columnWeight="1"
            android:layout_marginStart="4dp">

            <ProgressBar
                android:id="@+id/progressBar2"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/textItem2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Service Status"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Status Item 3: Watch Status -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="8dp"
            android:layout_row="1"
            android:layout_column="0"
            android:layout_columnWeight="1"
            android:layout_marginEnd="4dp">

            <ProgressBar
                android:id="@+id/progressBar3"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/textItem3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Watch Status"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Status Item 5: Data Received -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="8dp"
            android:layout_row="1"
            android:layout_column="1"
            android:layout_columnWeight="1"
            android:layout_marginStart="4dp">

            <ProgressBar
                android:id="@+id/progressBar5"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/textItem5"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Data Received"
                android:textSize="12sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/installOsdAppButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Install App"
                android:textSize="10sp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                style="@style/Widget.Material3.Button.TonalButton" />
        </LinearLayout>

        <!-- Status Item 6: Settings Status -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="8dp"
            android:layout_row="2"
            android:layout_column="0"
            android:layout_columnWeight="2"
            android:layout_columnSpan="2">

            <ProgressBar
                android:id="@+id/progressBar6"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/textItem6"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Settings Status"
                android:autoLink="web"
                android:textSize="12sp" />
        </LinearLayout>
    </GridLayout>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
