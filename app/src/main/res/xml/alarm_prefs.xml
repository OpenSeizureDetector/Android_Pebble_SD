<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android">
    <PreferenceCategory android:title="@string/AudibleAlarmSettingsTitle">
        <CheckBoxPreference
            android:defaultValue="true"
            android:key="AudibleAlarm"
            android:summary="@string/enable_audible_alarm_summary"
            android:title="@string/enable_audible_alarm_title" />
        <CheckBoxPreference
            android:defaultValue="true"
            android:key="AudibleWarning"
            android:summary="@string/enable_audible_warning_summary"
            android:title="@string/enable_audible_warning_title" />
        <CheckBoxPreference
            android:defaultValue="true"
            android:key="AudibleFaultWarning"
            android:summary="@string/enable_audible_fault_summary"
            android:title="@string/enable_audible_fault_title" />
        <EditTextPreference
            android:key="FaultTimerPeriod"
            android:title="@string/fault_timer_period_title"
            android:summary="@string/fault_timer_period_summary"
            android:numeric="integer"
            android:defaultValue="30" />
        <CheckBoxPreference
            android:defaultValue="true"
            android:key="DataFrequencyCheck"
            android:summary="@string/enable_data_frequency_check_summary"
            android:title="@string/enable_data_frequency_check_title" />
        <CheckBoxPreference
            android:defaultValue="false"
            android:key="UseMp3Alarm"
            android:summary="@string/use_mp3_alarm_summary"
            android:title="@string/use_mp3_alarm_title" />
        <!-- Sound file pickers — only visible when UseMp3Alarm is checked.
             Visibility is controlled programmatically in AlarmPrefsFragment. -->
        <Preference
            android:key="Mp3WarningUri"
            android:title="@string/mp3_warning_sound_title"
            android:summary="@string/mp3_warning_sound_summary_default" />
        <Preference
            android:key="Mp3AlarmUri"
            android:title="@string/mp3_alarm_sound_title"
            android:summary="@string/mp3_alarm_sound_summary_default" />
        <Preference
            android:key="Mp3FaultUri"
            android:title="@string/mp3_fault_sound_title"
            android:summary="@string/mp3_fault_sound_summary_default" />

    </PreferenceCategory>

    <PreferenceCategory android:title="@string/SMSAlarmSettingsTitle">
        <CheckBoxPreference
            android:defaultValue="false"
            android:key="SMSAlarm"
            android:summary="@string/enable_sms_alarm_summary"
            android:title="@string/enable_sms_alarm_title" />
        <EditTextPreference
            android:key="SMSDelayPeriod"
            android:title="@string/sms_delay_sec"
            android:summary="@string/sms_delay_sec_desc"
            android:inputType="number"
            android:defaultValue="30" />
        <EditTextPreference
            android:defaultValue=""
            android:key="SMSNumbers"
            android:summary="@string/sms_numbers_summary"
            android:title="@string/sms_numbers_title" />
        <EditTextPreference
            android:defaultValue="@string/DefaultSMSMsgText"
            android:key="SMSMsg"
            android:summary="@string/sms_message_summary"
            android:title="@string/sms_message_title" />
        <EditTextPreference
            android:defaultValue="@string/DefaultSMSFalseAlarmMsgText"
            android:key="SMSFalseAlarmMsg"
            android:summary="@string/sms_false_alarm_message_summary"
            android:title="@string/sms_false_alarm_message_title" />
    </PreferenceCategory>

    <PreferenceCategory android:title="@string/AlarmFunctionalitySettingsTitle">
        <CheckBoxPreference
            android:defaultValue="false"
            android:key="DisplayMainActivityOnAlarm"
            android:summary="@string/display_main_activity_on_alarm_summary"
            android:title="@string/display_main_activity_on_alarm_title" />
        <CheckBoxPreference
            android:defaultValue="false"
            android:key="LatchAlarms"
            android:summary="@string/latch_alarms_summary"
            android:title="@string/latch_alarms_title" />
        <EditTextPreference
            android:key="LatchAlarmTimerPeriod"
            android:title="@string/latch_timer_period_title"
            android:summary="@string/latch_timer_period_summary"
            android:numeric="integer"
            android:defaultValue="10" />
        <CheckBoxPreference
            android:defaultValue="true"
            android:key="EnableRaiseAlarmButton"
            android:summary="@string/enable_raise_alarm_button_summary"
            android:title="@string/enable_raise_alarm_button_title" />

    </PreferenceCategory>

